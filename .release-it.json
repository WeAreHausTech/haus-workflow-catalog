{
  "git": {
    "commitMessage": "chore(release): v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "Release v${version}",
    "requireCleanWorkingDir": true,
    "requireBranch": "main"
  },
  "github": {
    "release": false
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "before:init": "yarn validate",
    "before:bump": "node scripts/align-package-version-from-manifest.mjs",
    "after:bump": "node scripts/sync-manifest-version.mjs ${version}"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits",
        "types": [
          { "type": "feat", "section": "Added" },
          { "type": "fix", "section": "Fixed" },
          { "type": "perf", "section": "Changed" },
          { "type": "refactor", "section": "Changed" },
          { "type": "chore", "section": "Changed", "hidden": true },
          { "type": "docs", "section": "Changed", "hidden": true }
        ]
      },
      "infile": "CHANGELOG.md",
      "header": "# Changelog\n\nAll notable changes to this catalog are documented here.\nFormat: [Keep a Changelog](https://keepachangelog.com/en/1.1.0/)\nVersioning: [Semantic Versioning](https://semver.org/spec/v2.0.0.html)\n\nEach entry covers catalog-level changes (new/removed items, schema changes)\nand individual skill/agent version bumps. See `manifest.json` for per-item versions.\n\n---",
      "writerOpts": {
        "title": "## [<%= version %>] - <%= date %>"
      }
    }
  }
}
